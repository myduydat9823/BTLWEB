@model SubmitEntryViewModel

@{
    ViewData["Title"] = "Gửi bài dự thi";
}

<section class="contest-submit-shell">
    <a class="contest-detail-back" href="javascript:history.back()" style="margin-bottom: 16px; color: var(--brand-blue); display: inline-flex; align-items: center; gap: 6px; font-weight: 700;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Quay lại
    </a>

    <div class="contest-submit-card">
        <h1>&#128247; Gửi bài dự thi</h1>

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert--error">
                <span class="alert__icon">&#9888;</span>
                <span>@errorMessage</span>
            </div>
        }

        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 16px;"></div>

            <input type="hidden" asp-for="CompetitionId" />

            <div class="form-group">
                <label asp-for="PhotoTitle">Tiêu đề ảnh</label>
                <input asp-for="PhotoTitle" class="form-control" placeholder="Nhập tiêu đề cho bức ảnh của bạn..." />
                <span asp-validation-for="PhotoTitle" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhotoDescription">Mô tả ảnh</label>
                <textarea asp-for="PhotoDescription" class="form-control" rows="4" placeholder="Chia sẻ cảm hứng hoặc câu chuyện đằng sau bức ảnh..."></textarea>
                <span asp-validation-for="PhotoDescription" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhotoFiles">Chọn ảnh dự thi</label>
                <input asp-for="PhotoFiles" class="form-control" type="file" accept="image/*" multiple />
                <span asp-validation-for="PhotoFiles" class="text-danger"></span>
                <small class="text-muted">Chấp nhận các định dạng: JPG, PNG, GIF, WEBP. Kích thước tối đa: 10MB mỗi ảnh. Bạn có thể chọn nhiều ảnh cùng lúc.</small>
            </div>

            <div class="contest-submit-actions">
                <a class="btn btn-outline" href="javascript:history.back()">Hủy</a>
                <button class="btn btn-primary" type="submit">Gửi bài dự thi</button>
            </div>
        </form>
    </div>
</section>