@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
}

<section class="account-shell">
    <div class="account-card">
        <h1>Quên mật khẩu</h1>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (TempData["ResetPasswordLink"] is string resetLink)
        {
            <div class="alert alert-info">
                Project chưa cấu hình SMTP, nên link reset tạm thời hiện tại:
                <a href="@resetLink">@resetLink</a>
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Tạo liên kết đặt lại mật khẩu</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
