@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="account-shell">
    <div class="account-card">
        <h1>Đăng nhập</h1>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Identifier" class="form-label"></label>
                <input asp-for="Identifier" class="form-control" autocomplete="username" />
                <span asp-validation-for="Identifier" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <div class="account-actions">
                <button type="submit" class="btn btn-primary">Đăng nhập</button>
                <a asp-action="Register" class="btn btn-outline-secondary">Đăng ký</a>
                <a asp-action="ForgotPassword" class="btn btn-link">Quên mật khẩu?</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
