@model ChangeUserRoleViewModel

@{
    ViewData["Title"] = "Đổi role";
}

<section class="account-shell">
    <div class="account-card">
        <h1>Đổi role cho @Model.Username</h1>
        <p>Role hiện tại: <strong>@Model.CurrentRoleName</strong></p>

        <form method="post" action="/Admin/UserManagement/@Model.UserId/ChangeRole">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />
            <input asp-for="Username" type="hidden" />
            <input asp-for="CurrentRoleName" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="NewRoleId" class="form-label"></label>
                <select asp-for="NewRoleId" class="form-select">
                    @foreach (var role in Model.Roles)
                    {
                        <option value="@role.RoleId">@role.DisplayName (@role.RoleName)</option>
                    }
                </select>
                <span asp-validation-for="NewRoleId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Note" class="form-label"></label>
                <textarea asp-for="Note" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>

            <div class="account-actions">
                <button type="submit" class="btn btn-primary">Lưu role</button>
                <a class="btn btn-outline-secondary" href="/Admin/UserManagement/@Model.UserId">Hủy</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
